# Copy to .env and fill in your values. Do not commit .env.

# OpenRouter (or OpenAI) API key - for Whisper API and LLM summarization
OPEN_API_KEY=your_api_key_here
# Alternative name some clients expect
OPENAI_API_KEY=your_api_key_here

# OpenRouter base URL (leave empty for official OpenAI)
BASE_URL=https://openrouter.ai/api/v1

# Optional: max audio file size in MB for Whisper API chunking (default 4)
# WHISPER_API_MAX_FILE_MB=4
